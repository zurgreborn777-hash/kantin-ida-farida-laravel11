VITE_APP_NAME="${APP_NAME}"

DUITKU_MERCHANT_CODE=DS30983
DUITKU_API_KEY=
DUITKU_ENV=sandbox
DUITKU_CALLBACK_URL=https://kantin-ida-farida-railway-app.up.railway.app/callback
